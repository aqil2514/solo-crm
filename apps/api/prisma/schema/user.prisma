model User {
  id      String  @id @default(uuid()) @db.Uuid
  name    String?
  email   String  @unique
  picture String?
  role    String  @default("user")


  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  
  customerCategories CustomerCategory[]
  customerStatuses CustomerStatus[]
  customers Customers[]
}
